rules_version = '2';

// Craft rules based on data in your Firestore database
// allow write: if firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.isAdmin == true;
service firebase.storage {
  match /b/{bucket}/o {
    // Images can be read by anyone
    match /images/{allPaths=**} {
      allow read: if true;
      allow write: if true;
    }
    
    // Player images - anyone can read, anyone can write (for public photo capture)
    match /images/players/{filename} {
      allow read: if true;
      allow write: if true;
    }
  }
}